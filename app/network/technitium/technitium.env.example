# External IP bindings for Technitium DNS Server container ports.
# Copy this file to ~/.config/containers/systemd/technitium.env on the server and edit it.
# Do NOT commit the customized version to git.

# The dedicated IPv4 address of the local network interface
# The cloud firewall handles NAT to the public IP.
TECHNITIUM_BIND_IPV4=127.0.0.1

# The public/private IPv6 address of the server
# Default is set to the loopback IPv6 address for local development.
TECHNITIUM_BIND_IPV6=::1
