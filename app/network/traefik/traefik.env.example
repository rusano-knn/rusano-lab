# External IP bindings for Traefik container ports.
# Copy this file to ~/.config/containers/systemd/traefik.env on the server and edit it.
# Do NOT commit the customized version to git.

# The dedicated IPv4 address of the local network interface for Traefik
# The cloud firewall handles NAT to the public IP.
TRAEFIK_BIND_IPV4=127.0.0.1

# The dedicated IPv6 address of the local network interface for Traefik
# The cloud firewall handles NAT to the public IP.
TRAEFIK_BIND_IPV6=::1
